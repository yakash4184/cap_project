{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/auto-resolve",
      "schedule": "0 2 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(?<path>.*)",
      "dest": "/api/index.js?path=$path"
    },
    {
      "src": "/api",
      "dest": "/api/index.js"
    }
  ]
}
